# ── AI provider (required) ──────────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys  (free tier available)
OPENROUTER_API_KEY=sk-or-your-key-here

# OpenRouter exposes the same API interface as OpenAI, so this stays as-is.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── Database (set automatically by docker-compose) ──────────────────────────────
# Override this only when connecting to an external Postgres instance.
# DATABASE_URL=postgres://ankigen:ankigen@db:5432/ankigen

# ── Server (set automatically by docker-compose / render.yaml) ─────────────────
# PORT=8080
# NODE_ENV=production
# STATIC_DIR=/app/public
